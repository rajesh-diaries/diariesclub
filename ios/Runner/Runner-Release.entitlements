<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Production APNs environment for App Store / TestFlight builds. -->
	<!-- The development entitlement lives in Runner.entitlements and is -->
	<!-- used for Xcode-signed Debug/Profile builds. Switching at archive -->
	<!-- time prevents the silent "push works in dev, dies in prod" trap. -->
	<key>aps-environment</key>
	<string>production</string>
</dict>
</plist>
